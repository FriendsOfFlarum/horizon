{
    "name": "fof/horizon",
    "description": "Adds Laravel Horizon to Flarum",
    "keywords": [
        "extension",
        "flarum",
        "queue",
        "horizon"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "FriendsOfFlarum",
            "homepage": "https://friendsofflarum.org"
        }
    ],
    "support": {
        "issues": "https://github.com/FriendsOfFlarum/horizon/issues",
        "source": "https://github.com/FriendsOfFlarum/horizon"
    },
    "require": {
        "flarum/core": "^1.8",
        "laravel/horizon": "^5.21.3",
        "fof/redis": "1.x-dev",
        "vlucas/phpdotenv": "^5.2"
    },
    "autoload": {
        "psr-4": {
            "FoF\\Horizon\\": "src/"
        }
    },
    "extra": {
        "branch-alais": {
            "1.x": "1.x-dev"
        },
        "flarum-extension": {
            "title": "Horizon",
            "category": "feature",
            "icon": {
                "image": "resources/logo.svg",
                "backgroundColor": "#EBF1FD",
                "color": "#3a98d0",
                "backgroundSize": "90%",
                "backgroundRepeat": "no-repeat",
                "backgroundPosition": "center"
            }
        },
        "extiverse": {
            "discuss": "https://discuss.flarum.org/d/27520"
        },
        "flarum-cli": {
            "modules": {
                "githubActions": true
            }
        }
    },
    "require-dev": {
        "flarum/phpstan": "*"
    },
    "scripts": {
        "analyse:phpstan": "phpstan analyse",
        "clear-cache:phpstan": "phpstan clear-result-cache"
    },
    "scripts-descriptions": {
        "analyse:phpstan": "Run static analysis"
    }
}
